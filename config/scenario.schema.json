{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edge-c2.brumbiesoft.org/scenario.schema.json",
  "title": "Edge C2 Scenario",
  "description": "Schema for Edge C2 simulation scenario YAML files (v2.0)",
  "type": "object",
  "required": ["scenario"],
  "properties": {
    "scenario": {
      "$ref": "#/$defs/Scenario"
    }
  },

  "$defs": {

    "Scenario": {
      "type": "object",
      "required": ["name", "description", "duration_minutes", "center", "scenario_entities", "events"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Scenario identifier (e.g., 'SCN-MAL-02: Tanker Armed Robbery')"
        },
        "description": {
          "type": "string",
          "description": "Narrative overview of the scenario"
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440,
          "description": "Scenario length in minutes"
        },
        "center": {
          "$ref": "#/$defs/Position",
          "description": "Map center for COP initial view"
        },
        "zoom": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18,
          "default": 9,
          "description": "Map zoom level"
        },
        "background": {
          "type": "object",
          "description": "Background traffic configuration",
          "properties": {
            "include": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Background entity YAML files to include (e.g., ais_background_malacca.yaml)"
            },
            "entities": {
              "type": "array",
              "items": { "$ref": "#/$defs/Entity" },
              "description": "Inline background entity definitions"
            }
          },
          "additionalProperties": false
        },
        "scenario_entities": {
          "type": "array",
          "items": { "$ref": "#/$defs/Entity" },
          "minItems": 1,
          "description": "Entity definitions"
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/Event" },
          "description": "Timeline events"
        }
      },
      "additionalProperties": false
    },

    "Position": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "Latitude"
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "Longitude"
        },
        "alt_m": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Altitude in metres"
        },
        "speed_kn": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Initial speed in knots"
        },
        "heading_deg": {
          "type": "number",
          "minimum": 0,
          "maximum": 360,
          "default": 0,
          "description": "Initial heading in degrees true"
        }
      },
      "additionalProperties": false
    },

    "TimeOffset": {
      "type": "string",
      "pattern": "^[0-9]{1,2}:[0-9]{2}(:[0-9]{2})?$",
      "description": "Time offset from scenario start (HH:MM or HH:MM:SS)"
    },

    "Agency": {
      "type": "string",
      "enum": ["RMP", "MMEA", "CI", "RMAF", "MIL", "CIVILIAN", "IDN", "SGP"]
    },

    "Severity": {
      "type": "string",
      "enum": ["INFO", "WARNING", "CRITICAL"],
      "default": "INFO"
    },

    "EntityType": {
      "type": "string",
      "enum": [
        "CIVILIAN_BOAT",
        "CIVILIAN_CARGO",
        "CIVILIAN_COMMERCIAL",
        "CIVILIAN_FISHING",
        "CIVILIAN_LIGHT",
        "CIVILIAN_PASSENGER",
        "CIVILIAN_TANKER",
        "CIVILIAN_TANKER_VLCC",
        "CIVILIAN_TOURIST",
        "CI_IMMIGRATION_TEAM",
        "CI_OFFICER",
        "HOSTILE_PERSONNEL",
        "HOSTILE_VESSEL",
        "MIL_APC",
        "MIL_INFANTRY",
        "MIL_INFANTRY_SQUAD",
        "MIL_NAVAL",
        "MIL_NAVAL_FIC",
        "MIL_NAVAL_FRIGATE",
        "MIL_SUBMARINE",
        "MIL_SUBMARINE_FRIENDLY",
        "MIL_VEHICLE",
        "MMEA_FAST_INTERCEPT",
        "MMEA_PATROL",
        "RMAF_FIGHTER",
        "RMAF_HELICOPTER",
        "RMAF_MPA",
        "RMAF_TRANSPORT",
        "RMP_MARINE_PATROL",
        "RMP_OFFICER",
        "RMP_PATROL_BOAT",
        "RMP_PATROL_CAR",
        "RMP_TACTICAL_TEAM",
        "SUSPECT_FAST_BOAT",
        "SUSPECT_VESSEL"
      ]
    },


    "EventType": {
      "type": "string",
      "enum": [
        "DETECTION",
        "DISTRESS",
        "ALERT",
        "ORDER",
        "AIS_LOSS",
        "BOARDING",
        "INTERCEPT",
        "ARRIVAL",
        "RESOLUTION",
        "RECLASSIFY"
      ]
    },

    "Action": {
      "type": "string",
      "description": "Event action dispatched to the actionee entity. Note: DEPRECATED values (boarding, patrol, search_area) are retained for v1_archive compatibility only — new scenarios must not use them; they are excluded from every domain's action whitelist. Use `alongside` for vessel-to-vessel approach and `disembark` (with optional onto:) for personnel transfer.",
      "enum": [
        "transit",
        "orbit",
        "hold_station",
        "alongside",
        "intercept",
        "pursue",
        "escape",
        "approach",
        "rtb",
        "embark",
        "disembark",
        "deploy",
        "respond",
        "lockdown",
        "secure",
        "activate",
        "escort_to_port",
        "reclassify",
        "boarding",
        "search_area",
        "patrol"
      ]
    },

    "OnCompleteAction": {
      "type": "string",
      "enum": [
        "hold_station",
        "alongside",
        "orbit",
        "rtb",
        "barrier",
        "escort"
      ],
      "description": "Follow-on behavior after action completes. alongside is maritime-only — locks the entity's current geographic offset to the target."
    },

    "OrbitDirection": {
      "type": "string",
      "enum": ["CW", "CCW"],
      "default": "CW"
    },

    "Waypoint": {
      "type": "object",
      "required": ["lat", "lon", "time"],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "speed": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Speed in knots"
        },
        "time": {
          "$ref": "#/$defs/TimeOffset"
        },
        "alt_m": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "metadata": {
          "type": "object",
          "properties": {
            "sidc": {
              "type": "string",
              "minLength": 10,
              "maxLength": 20,
              "description": "SIDC override (MIL-STD-2525D)"
            },
            "callsign": {
              "type": "string",
              "description": "Callsign override"
            }
          },
          "additionalProperties": true,
          "description": "Property overrides applied at this waypoint"
        }
      },
      "additionalProperties": false
    },

    "MaritimeMetadata": {
      "type": "object",
      "properties": {
        "mmsi":           { "type": "string", "pattern": "^[0-9]{9}$", "description": "Maritime Mobile Service Identity (9 digits)" },
        "imo":            { "type": "string", "description": "IMO number" },
        "flag":           { "type": "string", "description": "Flag state (ISO 3166-1 alpha-3, e.g., MYS)" },
        "vessel_type":    { "type": "string", "description": "Hull type description" },
        "length_m":       { "type": "number", "minimum": 1, "description": "Length overall in metres" },
        "draught_m":      { "type": "number", "minimum": 0, "description": "Draught in metres" },
        "cargo":          { "type": "string", "description": "Cargo description" },
        "destination_declared": { "type": "string", "description": "Declared destination port" },
        "last_port":      { "type": "string", "description": "Last port of call" },
        "ais_active":     { "type": "boolean", "default": true, "description": "AIS transponder active" },
        "nav_status":     { "type": "string", "description": "AIS navigational status" },
        "armed":          { "type": "boolean", "description": "Weapons aboard" },
        "estimated_crew": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },

    "AirMetadata": {
      "type": "object",
      "properties": {
        "aircraft_type":  { "type": "string", "description": "Aircraft model (e.g., Airbus H225M Caracal)" },
        "adsb_hex":       { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "ADS-B hex code (ICAO 24-bit address)" },
        "ident":          { "type": "string", "description": "Squawk / flight ID" },
        "registration":   { "type": "string", "description": "Aircraft registration (e.g., M54-04)" },
        "home_base":      { "$ref": "#/$defs/Position", "description": "RTB destination" },
        "armed":          { "type": "boolean" },
        "estimated_crew": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },

    "GroundMetadata": {
      "type": "object",
      "properties": {
        "vehicle_type":   { "type": "string", "description": "Vehicle model" },
        "registration":   { "type": "string", "description": "Vehicle registration plate" },
        "armed":          { "type": "boolean" },
        "estimated_crew": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },

    "PersonnelMetadata": {
      "type": "object",
      "properties": {
        "unit_name":      { "type": "string", "description": "Unit designation" },
        "personnel_count": { "type": "integer", "minimum": 1, "description": "Team size" },
        "equipment":      { "type": "array", "items": { "type": "string" }, "description": "Equipment list" },
        "armed":          { "type": "boolean" },
        "notes":          { "type": "string" }
      },
      "additionalProperties": true
    },

    "Entity": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9_-]+$",
          "description": "Unique entity identifier"
        },
        "type": {
          "$ref": "#/$defs/EntityType"
        },
        "callsign": {
          "type": "string",
          "description": "Display name (defaults to id)"
        },
        "agency": {
          "$ref": "#/$defs/Agency",
          "description": "Owning agency (defaults to entity type default)"
        },
        "sidc": {
          "type": "string",
          "minLength": 20,
          "maxLength": 20,
          "pattern": "^[0-9]{20}$",
          "description": "MIL-STD-2525D 20-char numeric SIDC (overrides entity type default)"
        },
        "initial_position": {
          "$ref": "#/$defs/Position",
          "description": "Starting location (required unless embarked_on is set)"
        },
        "embarked_on": {
          "type": "string",
          "description": "Entity ID of carrier. Entity is hidden and tracks carrier until disembark action."
        },
        "spawn_at": {
          "$ref": "#/$defs/TimeOffset",
          "description": "Entity hidden until this scenario time"
        },
        "waypoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/Waypoint" },
          "minItems": 1,
          "description": "Explicit movement path (optional — use events with actions instead)"
        },
        "metadata": {
          "type": "object",
          "description": "Domain-specific data (see MaritimeMetadata, AirMetadata, etc.)",
          "additionalProperties": true
        },
        "behavior": {
          "type": "string",
          "description": "LEGACY — ignored in v2. Do not use in new scenarios."
        },
        "patrol_area": {
          "type": "string",
          "description": "LEGACY — ignored in v2."
        }
      },
      "additionalProperties": false,

      "allOf": [
        {
          "_comment": "Entity must have initial_position OR embarked_on",
          "anyOf": [
            { "required": ["initial_position"] },
            { "required": ["embarked_on"] }
          ]
        }
      ]
    },

    "Event": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "id":                { "type": "string", "description": "Event identifier for cross-referencing and dependency chains" },
        "time":              { "$ref": "#/$defs/TimeOffset", "description": "Absolute scenario time to fire" },
        "after": {
          "type": "object",
          "required": ["event"],
          "properties": {
            "event": { "type": "string", "description": "Event ID to depend on" },
            "phase": { "type": "string", "enum": ["initiate", "complete"], "default": "initiate", "description": "Fire after event initiates or completes" },
            "offset": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$", "description": "Time offset in HH:MM:SS format" }
          },
          "additionalProperties": false,
          "description": "Dependency trigger — fire after another event"
        },
        "type":              { "$ref": "#/$defs/EventType" },
        "description":       { "type": "string", "description": "Author's intent — not displayed in timeline" },
        "on_initiate":       { "type": "string", "description": "Timeline message when event fires" },
        "on_complete":       { "type": "string", "description": "Timeline message when action completes" },
        "severity":          { "$ref": "#/$defs/Severity" },
        "target":            { "type": "string", "description": "Single entity ID to act on" },
        "targets":           { "type": "array", "items": { "type": "string" }, "description": "Multiple entity IDs" },
        "source":            { "type": "string", "description": "Originating entity ID" },
        "alert_agencies":    { "type": "array", "items": { "$ref": "#/$defs/Agency" }, "default": [] },
        "position":          { "$ref": "#/$defs/Position", "description": "Event location" },
        "action":            { "$ref": "#/$defs/Action" },
        "on_complete_action": { "$ref": "#/$defs/OnCompleteAction" },
        "destination":       { "$ref": "#/$defs/Position", "description": "Target location (transit/deploy)" },
        "speed":             { "type": "number", "minimum": 0, "description": "Speed in knots" },
        "altitude_m":        { "type": "number", "minimum": 0, "description": "Altitude for air entities" },
        "intercept_target":  { "type": "string", "description": "DEPRECATED — use top-level `target`. Entity ID to intercept." },
        "intercept_radius_nm": { "type": "number", "minimum": 0.01, "maximum": 10, "description": "Distance at which intercept completes. When both intercept_radius_nm and on_complete_action=orbit with orbit_radius_nm are set, intercept_radius_nm wins." },
        "onto":              { "type": "string", "description": "disembark only: teleport disembarked entity to this entity's position (instead of carrier) and assign HoldStationMovement tracking it." },
        "orbit_center":      { "type": "string", "description": "Entity ID to orbit around" },
        "orbit_center_lat":  { "type": "number", "minimum": -90, "maximum": 90 },
        "orbit_center_lon":  { "type": "number", "minimum": -180, "maximum": 180 },
        "orbit_radius_nm":   { "type": "number", "minimum": 0.01, "maximum": 50, "default": 1.0 },
        "orbit_speed":       { "type": "number", "minimum": 0, "description": "Orbit speed in knots" },
        "orbit_direction":   { "$ref": "#/$defs/OrbitDirection" },
        "hold_target":       { "type": "string", "description": "Entity ID to hold alongside" },
        "bearing_deg":       { "type": "number", "minimum": 0, "maximum": 360 },
        "duration_min":      { "type": "number", "minimum": 0 },
        "approach_target":   { "type": "string", "description": "Entity ID to approach" },
        "final_speed":       { "type": "number", "minimum": 0, "default": 2 },
        "approach_distance_nm": { "type": "number", "minimum": 0, "default": 1.0 },
        "sidc_override":     { "type": "string", "minLength": 10, "maxLength": 20 },
        "callsign_override": { "type": "string" },
        "boarding_target":   { "type": "string", "description": "DEPRECATED — boarding action is a no-op; use alongside for vessels or disembark (with onto:) for personnel." },
        "area":              { "type": "string", "description": "GeoJSON zone reference" }
      },

      "anyOf": [
        { "required": ["time"] },
        { "required": ["after"] }
      ],

      "allOf": [

        {
          "_comment": "Events with any action MUST have target or targets",
          "if": { "required": ["action"] },
          "then": {
            "anyOf": [
              { "required": ["target"] },
              { "required": ["targets"] }
            ]
          }
        },

        {
          "_comment": "action: transit REQUIRES destination",
          "if": { "properties": { "action": { "const": "transit" } }, "required": ["action"] },
          "then": { "required": ["destination"] }
        },

        {
          "_comment": "action: deploy REQUIRES destination",
          "if": { "properties": { "action": { "const": "deploy" } }, "required": ["action"] },
          "then": { "required": ["destination"] }
        },

        {
          "_comment": "action: respond REQUIRES destination",
          "if": { "properties": { "action": { "const": "respond" } }, "required": ["action"] },
          "then": { "required": ["destination"] }
        },

        {
          "_comment": "action: intercept REQUIRES intercept_target",
          "if": { "properties": { "action": { "const": "intercept" } }, "required": ["action"] },
          "then": { "required": ["intercept_target"] }
        },

        {
          "_comment": "action: escape REQUIRES bearing_deg",
          "if": { "properties": { "action": { "const": "escape" } }, "required": ["action"] },
          "then": { "required": ["bearing_deg"] }
        },

        {
          "_comment": "action: approach REQUIRES approach_target OR destination",
          "if": { "properties": { "action": { "const": "approach" } }, "required": ["action"] },
          "then": {
            "anyOf": [
              { "required": ["approach_target"] },
              { "required": ["destination"] }
            ]
          }
        },

        {
          "_comment": "type: AIS_LOSS REQUIRES target",
          "if": { "properties": { "type": { "const": "AIS_LOSS" } } },
          "then": {
            "anyOf": [
              { "required": ["target"] },
              { "required": ["targets"] }
            ]
          }
        },

        {
          "_comment": "type: BOARDING REQUIRES target and boarding_target",
          "if": { "properties": { "type": { "const": "BOARDING" } } },
          "then": { "required": ["target", "boarding_target"] }
        },

        {
          "_comment": "after dependency REQUIRES event field",
          "if": { "required": ["after"] },
          "then": {
            "properties": {
              "after": { "required": ["event"] }
            }
          }
        }
      ],

      "additionalProperties": true
    }
  }
}
